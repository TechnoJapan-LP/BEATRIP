{
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/newsletter/digest",
      "schedule": "0 1 * * 1"
    }
  ],
  "functions": {
    "src/app/api/cron/scrape/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/admin/scrape/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/sales/scrape/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/sales/test-traicy/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/newsletter/digest/route.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ]
}
