# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# ユーザー固有データ（クリック・購読など）
# data/sales/ はビルド時にバンドルする必要があるため git に含める
/data/subscriptions.json
/data/alerts.json
/data/clicks/

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code ローカル設定
.claude/settings.local.json
.claude/worktrees/

# editor/merge backup files
*.orig
*.bak

# skills.sh で入れたエージェント用スキルの実体 (公開リポジトリに1MB弱を抱えない)。
# skills-lock.json はコミットしてあるので `npx skills add` で同じ版を再現できる。
.agents/
.claude/skills/
