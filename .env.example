# ── スクレイパー設定 ──
# mock: モックデータを返す（開発用・デフォルト）
# live: 各航空会社サイトを実際にスクレイプ
# hybrid: Traicy RSS + 航空会社公式サイト（推奨）
SCRAPER_MODE=mock

# ── Cron認証 ──
# スクレイプCronジョブの認証トークン
CRON_SECRET=your-cron-secret-here

# ── 管理API ──
# /api/deals/manual の認証キー
ADMIN_API_KEY=your-admin-api-key-here

# ── LINE通知 ──
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# ── ニュースレター（Resend） ──
# https://resend.com で取得したAPIキー
RESEND_API_KEY=your-resend-api-key-here
# 送信元アドレス（独自ドメインをResendで認証後に設定。未設定時はResendテスト用アドレス）
RESEND_FROM=BEATRIP <noreply@beatrip.jp>
# 配信停止リンクの署名鍵（任意。未設定時は CRON_SECRET を使用）
NEWSLETTER_SECRET=your-newsletter-secret-here

# ── TravelPayouts 拡張パートナー（任意・承認後にENVを入れた分だけ自動有効化）
# TravelPayouts ダッシュボード → Programs から各社を承認 → 「program ID」(URL中の p= 値) をコピー
# https://www.travelpayouts.com/programs を参照
#
# ホテル: Booking.com
TP_BOOKING_PROGRAM_ID=
# ホテル: Trip.com（フライト用とは別 ID の可能性）
TP_TRIP_HOTEL_PROGRAM_ID=
# eSIM: Airalo
TP_AIRALO_PROGRAM_ID=
# ホテル: Agoda（curated hotels の予約ボタン用）
TP_AGODA_PROGRAM_ID=

# ── ホテル価格データソース（任意） ──
# HOTEL_PRICE_SOURCE=booking_cache に設定し TP_BOOKING_FEED_URL を入れると、
# /hotels/[city] のスターティング価格を Booking cache feed 経由の実データに切替。
# 未設定なら priceFromJpy（編集者ベースライン）にシーズン係数を掛けた推定値が表示される。
#
# 入手方法:
#   1. TravelPayouts ダッシュボード → Programs → Booking.com を Apply
#   2. 承認後 → Tools → Hotel Data Feeds で JSON ダウンロード URL を取得
#   3. その URL を TP_BOOKING_FEED_URL に貼り、HOTEL_PRICE_SOURCE=booking_cache に
#
# 期待される JSON 形式（最低限）:
#   [{ "city_slug": "tokyo", "city_iata": "TYO", "min_price_jpy": 9800 }, ...]
HOTEL_PRICE_SOURCE=season_adjusted
TP_BOOKING_FEED_URL=
# 空港送迎: KiwiTaxi
TP_KIWITAXI_PROGRAM_ID=
# 海外旅行保険（任意プロバイダ）
TP_INSURANCE_PROGRAM_ID=
# 保険のリンク先URL（プロバイダ固有。program ID と組み合わせて使う）
TP_INSURANCE_URL=

# ── A8.net (ASP) — 日本系広告主の affiliate（任意・承認後にENVを入れた分だけ自動有効化）
# A8 マイページ → プログラム検索 → 該当広告主 → 広告リンク → 掲載サイトに
# BEATRIP【アピールサイト】を選択 → テキスト → コピーした HTML の a8mat 値
# (例: "4B5OO8+1NJE1M+AD2+67RK2") をそのまま貼る。
# 未設定の partner は UI で表示されない。
#
# BEATRIP のメディア ID = a8mat の第1セグメント "4B5OO8" (全 partner 共通)。
# 4B5OO6 等の他のメディア ID が混じっていたら別サイト用 → 取り直し必要。
#
# ─── エアトリ系 ───
A8_AIRTRIP_DOMESTIC_FLIGHT_MAT=    # エアトリ 国内航空券 (本命)
A8_AIRTRIP_RENTAL_MAT=             # エアトリ レンタカー (ECID s00000001343)
A8_AIRTRIP_NIGHT_BUS_MAT=          # エアトリ 夜行・高速バス
A8_AIRTRIP_OVERSEAS_PACKAGE_MAT=   # エアトリ 海外航空券＋ホテル
A8_AIRTRIP_PLUS_MAT=               # エアトリプラス (国内航空券＋ホテル)
A8_AIRTRIP_DOMESTIC_TOUR_MAT=      # エアトリ 国内ツアー (沖縄・北海道)
A8_AIRTRIP_HAWAII_MAT=             # エアトリハワイ
A8_AIRTRIP_DOMESTIC_HOTEL_MAT=     # エアトリ 国内ホテル予約
# ─── 大手代理店・ツアー ───
A8_JTB_MAT=                       # JTB (ECID s00000005350)
A8_OKINAWA_TOURIST_MAT=           # 沖縄ツーリスト (ECID s00000026857)
A8_NEWT_MAT=                      # NEWT / 令和トラベル (ECID s00000025498)
# ─── ホテル系 ───
A8_YAHOO_TRAVEL_MAT=              # Yahoo!トラベル (ECID s00000023244)
A8_ICHIKYU_MAT=                   # 一休.com (ECID s00000000218)
A8_JALAN_MAT=                     # じゃらんnet
A8_TRAVELIST_HOTEL_MAT=           # トラベリスト 国内ホテル
A8_RESORT_GLAMPING_MAT=           # リゾートグランピングドットコム
# ─── 海外航空券・ツアー ───
A8_TRAVELWEST_FLIGHT_MAT=         # トラベルウエスト 海外航空券
A8_TRAVELWEST_PACKAGE_MAT=        # トラベルウエスト ダイナミックパッケージ
A8_TRAVELWEST_TOUR_MAT=           # トラベルウエスト 海外ツアー
A8_TRAVELIST_OVERSEAS_FLIGHT_MAT= # Travelist 海外格安航空券
# ─── 国内航空券 (エアトリ以外) ───
A8_REAL_TICKET_MAT=               # リアルチケット
A8_CHEAP_FLIGHT_MALL_MAT=         # 格安航空券モール
A8_TRAVELIST_DOMESTIC_FLIGHT_MAT= # トラベリスト 国内航空券
# ─── 鉄道・交通 ───
A8_NAVITIME_RAIL_MAT=             # NAVITIME 新幹線・特急
A8_NAVITIME_FLIGHT_MAT=           # NAVITIME 国内線航空券
A8_OMIO_MAT=                      # Omio 欧州交通
A8_AIRPORT_SHUTTLE_MAT=           # エアポートシャトル 空港送迎
# ─── 現地ツアー・アクティビティ ───
A8_BUYMA_TRAVEL_MAT=              # BUYMA TRAVEL 現地日本語ガイドツアー
A8_TABIRAI_ACTIVITY_MAT=          # たびらいアクティビティ (沖縄・北海道)
# ─── 通信 (eSIM / Wi-Fi) ───
A8_GLOBAL_WIFI_MAT=                # グローバルWiFi (ECID s00000011875)
A8_VOYE_GLOBAL_MAT=                # ボイエグローバル eSIM
A8_TRIFA_MAT=                      # トリファ eSIM アプリ
A8_TORA_ESIM_MAT=                  # TORA eSIM
A8_JAPAN_GLOBAL_ESIM_MAT=          # JAPAN&GLOBAL eSIM (192地域対応)
A8_SAILY_MAT=                      # Saily eSIM
# ─── 航空会社直販 ───
A8_QATAR_AIRWAYS_MAT=              # Qatar Airways
# ─── ホテル (グローバル) ───
A8_AGODA_MAT=                      # agoda 国内・海外ホテル
# ─── 海外オプショナルツアー・現地サービス ───
A8_KKDAY_MAT=                      # KKday 海外オプショナルツアー
A8_OOOH_MAT=                       # Oooh 現地旅行会社マッチング
# ─── 国内旅行・ツアー (追加) ───
A8_BIG_HOLIDAY_MAT=                # ビッグホリデー 国内旅行
A8_NIPPON_TRAVEL_MAT=              # 日本旅行 国内・海外ツアー
A8_J_TRIP_MAT=                     # J-TRIP (JALで行く国内旅行)
A8_NEEDS_TOUR_MAT=                 # ニーズツアー 国内・沖縄
A8_TRAVELWEST_DOMESTIC_PACKAGE_MAT= # トラベルウエスト 国内航空券＋宿泊
# ─── クルーズ ───
A8_BEST_ONE_CRUISE_MAT=            # ベストワンクルーズ 船旅専門

# ─── A8.net クレジットカード ───
A8_EPOS_CARD_MAT=                  # エポスカード (年会費無料・海外旅行保険自動付帯)
A8_SAISON_BLUE_AMEX_MAT=           # セゾン・ブルー・アメックス (26歳以下年会費無料)
A8_MUFG_CARD_MAT=                  # 三菱 UFJ カード
# ─── A8.net 海外旅行保険 ───
A8_SOMPO_INSURANCE_MAT=            # 損保ジャパン 新・海外旅行保険【off!】
A8_TABIHO_INSURANCE_MAT=           # tabiho（たびほ）海外旅行保険

# ── クレカ・保険系 ASP 中立 click URL (任意 ASP のクリック URL をそのまま貼る)
#
# クレカ・保険系は ASP の改廃が頻繁 (例: アメックスがバリューコマース廃止 →
# Rakuten Advertising / TGアフィリエイト経由) のため、env 名は ASP 名を含めず
# `AFFILIATE_URL_*` プレフィックスに統一。バリューコマース / アクセストレード /
# 楽天アフィリエイト / Rakuten Advertising / TGアフィリエイト / felmat など、
# どの ASP のクリック URL を入れても動作する。
#
# 値には ASP 管理画面で発行されたクリック URL を http(s):// から丸ごと貼る:
#   (例) https://ck.jp.ap.valuecommerce.com/servlet/referral?sid=...&pid=...
#   (例) https://h.accesstrade.net/sp/cc?rk=...&trflg=1
#   (例) https://hb.afl.rakuten.co.jp/hgc/...
#   (例) https://rpx.a8.net/svt/ejp?...   (TGアフィリエイト等の独自ドメインでも可)
# 未設定の partner は UI で表示されない。
#
# ─── クレジットカード ───
AFFILIATE_URL_AMEX_SKYTRAVELER=    # アメックス・スカイ・トラベラー  / 推奨ASP: Rakuten Advertising / TGアフィリエイト / felmat / 直接申込
AFFILIATE_URL_AMEX_GOLD=           # アメックス・ゴールド・プリファード / 推奨ASP: Rakuten Advertising / TGアフィリエイト / felmat / 直接申込
AFFILIATE_URL_AMEX_PLATINUM=       # アメックス・プラチナ            / 推奨ASP: Rakuten Advertising / TGアフィリエイト / felmat / 直接申込
AFFILIATE_URL_DINERS_CLUB=         # ダイナースクラブカード          / 推奨ASP: バリューコマース / Rakuten Advertising
AFFILIATE_URL_JAL_CARD=            # JAL カード                     / 推奨ASP: アクセストレード / felmat
AFFILIATE_URL_ANA_CARD=            # ANA カード                     / 推奨ASP: アクセストレード
AFFILIATE_URL_SMBC_NL=             # 三井住友カード（NL）            / 推奨ASP: アクセストレード / felmat
AFFILIATE_URL_PAYPAY_CARD=         # PayPay カード                  / 推奨ASP: アクセストレード
AFFILIATE_URL_RAKUTEN_CARD=        # 楽天カード                     / 推奨ASP: 楽天アフィリエイト (即時)
AFFILIATE_URL_JCB_CARD_W=          # JCB CARD W                     / 推奨ASP: バリューコマース
AFFILIATE_URL_D_CARD_GOLD=         # dカード GOLD                   / 推奨ASP: A8.net / バリューコマース
AFFILIATE_URL_RECRUIT_CARD=        # リクルートカード               / 推奨ASP: A8.net
AFFILIATE_URL_LIFE_CARD=           # ライフカード                   / 推奨ASP: A8.net
AFFILIATE_URL_AEON_CARD=           # イオンカードセレクト           / 推奨ASP: A8.net
# ─── 海外旅行保険 ───
AFFILIATE_URL_AIG_INSURANCE=       # AIG 損保 海外旅行保険           / 推奨ASP: バリューコマース / Rakuten Advertising
AFFILIATE_URL_CHUBB_INSURANCE=     # Chubb 損保 海外旅行保険         / 推奨ASP: アクセストレード
AFFILIATE_URL_RAKUTEN_INSURANCE=   # 楽天損保 海外旅行保険           / 推奨ASP: 楽天アフィリエイト (即時)

# ── 航空会社直販 ASP (設定すると予約 CTA が ASP 経由になり収益化) ──
#
# 各 ASP で発行されたクリック URL 全文を http(s):// から丸ごと貼る
# (クレカ・保険系の AFFILIATE_URL_* と同じ規約。ASP 中立)。
# 未設定の航空会社は従来挙動 (公式 deep link or Skyscanner) のまま。
#
# 注: ASP リンクは経路パラメータ (出発地/目的地/日付) を引き継げず、
# 公式サイトのトップ or キャンペーンページ着地になります。
# 「路線プリフィル済み予約画面の UX」と「ASP 成果報酬」のどちらを取るかは
# この env を設定するかどうかで運用者が選択してください。
# 設定状況は /admin の「航空会社 ASP 設定状況」で確認できます。
AFFILIATE_URL_AIRLINE_JAL=          # JAL 国内線・国際線    / 推奨ASP: レントラックス (クローズド) / J-A-NET
AFFILIATE_URL_AIRLINE_ANA=          # ANA                  / ASP 取扱い限定的 (見つかれば設定)
AFFILIATE_URL_AIRLINE_PEACH=        # Peach                / A8 で要検索
AFFILIATE_URL_AIRLINE_JETSTAR=      # Jetstar              / A8 / アクセストレードで要検索
AFFILIATE_URL_AIRLINE_SQ=           # シンガポール航空      / アクセストレード等で要検索
AFFILIATE_URL_AIRLINE_CX=           # キャセイパシフィック  / アクセストレード等で要検索
AFFILIATE_URL_AIRLINE_VJ=           # VietJet Air          / 海外系 ASP で要検索
AFFILIATE_URL_AIRLINE_QR=           # Qatar Airways        / A8 に既存プログラムあり (A8_QATAR_AIRWAYS_MAT 参照)

# ── 旅行用品 物販 (もしもアフィリエイト かんたんリンク等。記事内に表示) ──
#
# もしもの「かんたんリンク」(Amazon/楽天/Yahoo を 1 ボタンに集約) or
# Amazon/楽天の個別商品リンク URL を http(s):// から丸ごと貼る
# (航空会社 ASP / クレカ・保険系の AFFILIATE_URL_* と同じ規約)。
# 未設定の商品はガイド記事の物販ブロックに表示されません (全未設定ならブロックごと非表示)。
# 設定状況は /admin の「物販 (旅行用品) 設定状況」で確認できます。
AFFILIATE_URL_GOODS_SUITCASE=        # スーツケース (もしも かんたんリンク)
AFFILIATE_URL_GOODS_POWER_ADAPTER=   # 変換プラグ・変圧器
AFFILIATE_URL_GOODS_POWER_BANK=      # モバイルバッテリー
AFFILIATE_URL_GOODS_NECK_PILLOW=     # ネックピロー
AFFILIATE_URL_GOODS_COMPRESSION_BAG= # 圧縮袋・パッキングキューブ
AFFILIATE_URL_GOODS_PASSPORT_CASE=   # パスポートケース・防犯ポーチ
AFFILIATE_URL_GOODS_MOBILE_WIFI=     # 海外用 WiFi / eSIM 端末
AFFILIATE_URL_GOODS_TRAVEL_KIDS=     # 子連れ便利グッズ

# ── SNS自動発信: Bluesky ──
# https://bsky.app でアカウント作成 → Settings → Advanced → App passwords で発行
# (アカウントログイン用パスワードではなく、専用 App password を使うこと)
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=

# ── AI チャット (Anthropic Claude) ──
# https://console.anthropic.com で取得した API キー
# 未設定なら /api/chat は 503 を返し、UI ウィジェットも非表示になる
ANTHROPIC_API_KEY=
# UI 側のフローティング起動ボタンを表示するスイッチ ("1" で有効)
# サーバー側 ANTHROPIC_API_KEY とセットで設定すること
NEXT_PUBLIC_ENABLE_CHAT=

# ── Google Places API (ホテル実物写真の取得) ──
# https://console.cloud.google.com で Places API (New) を有効化し API key を発行
# /admin の「ホテル写真リフレッシュ (Google Places)」ボタンで一括取得 → KV にキャッシュ
# (30 日 TTL)。Wikimedia でカバーしきれない 100+ ホテルの実物写真をカバーする。
# 月 $200 無料クレジット内で 154 ホテル一括取得は数 $ 程度で完了。
# 本番では Cloud Console 側で HTTP リファラ制限 + Places API Photo Media SKU のみ
# 許可することで key 漏えい時のリスクを抑える。未設定でも build/runtime は通る (fallback)。
GOOGLE_PLACES_API_KEY=

# ── 今後の拡張用 ──
# SKYSCANNER_API_KEY=
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
